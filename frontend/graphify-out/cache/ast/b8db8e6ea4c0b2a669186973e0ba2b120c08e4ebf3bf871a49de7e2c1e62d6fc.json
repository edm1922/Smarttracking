ce_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1899"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "toLocaleTimeString", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1900"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "join", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1929"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "filter", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1929"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "map", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1929"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "map", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L1997"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "toLocaleDateString", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L2039"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "toLocaleDateString", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L2039"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "toLocaleDateString", "is_member_call": true, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L2039"}, {"caller_nid": "unit_tracking_page_unittrackingpage", "callee": "(() => {\r\n                const start = new Date(stockHealthRange.start);\r\n                const end = new Date(stockHealthRange.end);\r\n                end.setHours(23, 59, 59, 999);\r\n\r\n                const relevantRequests = requests.filter(r => {\r\n                  const d = new Date(r.createdAt);\r\n                  return r.status === 'APPROVED' && \r\n                  (r.item.product?.name === viewingStockDetail.name || r.item.name === viewingStockDetail.name) &&\r\n                  d >= start && d <= end;\r\n                });\r\n\r\n                if (relevantRequests.length === 0) {\r\n                  return (\r\n                    <div className=\"text-center py-12\">\r\n                      <History className=\"h-12 w-12 text-gray-200 mx-auto mb-4\" />\r\n                      <p className=\"text-sm font-bold text-gray-400 italic\">No specific movements found for this item on this date.</p>\r\n                    </div>\r\n                  );\r\n                }\r\n\r\n                // Group by specs\r\n                const breakdown: Record<string, { specs: string[], total: number }> = {};\r\n                relevantRequests.forEach(r => {\r\n                  const specString = r.item.fieldValues?.map((fv: any) => {\r\n                    const v = fv.value;\r\n                    const val = v && typeof v === 'object' ? (v.main ?? v.qty) : v;\r\n                    return val ? `${fv.field?.name || 'Spec'}: ${val}` : '';\r\n                  }).filter(Boolean).join(', ') || 'No Specs';\r\n                  \r\n                  if (!breakdown[specString]) {\r\n                    breakdown[specString] = { specs: specString.split(', '), total: 0 };\r\n                  }\r\n                  breakdown[specString].total += r.qty;\r\n                });\r\n\r\n                return (\r\n                  <div className=\"space-y-4\">\r\n                    {Object.entries(breakdown).map(([key, data], idx) => (\r\n                      <div key={idx} className=\"flex items-center justify-between p-5 bg-gray-50 rounded-3xl border border-gray-100 group hover:border-orange-200 transition-all\">\r\n                        <div className=\"space-y-1\">\r\n                          <p className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">Variation Breakdown</p>\r\n                          <div className=\"flex flex-wrap gap-1.5\">\r\n                            {data.specs.map((s, i) => (\r\n                              <span key={i} className=\"px-2 py-0.5 bg-white border border-gray-200 text-[9px] font-bold text-gray-600 rounded-md\">\r\n                                {s}\r\n                              </span>\r\n                            ))}\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"text-right\">\r\n                          <p className=\"text-[10px] font-black text-orange-600 uppercase tracking-widest\">Moved Qty</p>\r\n                          <p className=\"text-2xl font-black text-gray-900\">-{data.total}</p>\r\n                        </div>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                );\r\n              })", "is_member_call": false, "source_file": "C:\\Users\\EDRON\\Desktop\\Dev Apps\\QR tracker\\frontend\\src\\app\\dashboard\\unit-tracking\\page.tsx", "source_location": "L2052"}]}