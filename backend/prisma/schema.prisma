generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String               @id @default(uuid())
  username           String               @unique
  password           String
  role               String               @default("viewer")
  createdAt          DateTime             @default(now())
  ActivityLog        ActivityLog[]
  ProductTransaction ProductTransaction[]
  PullOutRequest     PullOutRequest[]
}

model Item {
  id           String           @id @default(uuid())
  slug         String           @unique
  name         String?
  description  String?
  status       String           @default("Available")
  locked       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  imageUrl     String?
  batchId      String?
  categoryId   String?
  statusId     String?
  isLegacy     Boolean          @default(false)
  supplierId   String?
  unit         String?          @default("pcs")
  trackingType String           @default("INDIVIDUAL")
  ActivityLog  ActivityLog[]
  batch        Batch?           @relation(fields: [batchId], references: [id])
  category     Category?        @relation(fields: [categoryId], references: [id])
  statusRef    Status?          @relation(fields: [statusId], references: [id])
  fieldValues  ItemFieldValue[]
  tags         ItemTag[]
  pullOutRequests PullOutRequest[]
}

model PullOutRequest {
  id        String   @id @default(uuid())
  itemId    String
  userId    String
  qty       Int
  unit      String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  remarks   String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  items     Item[]
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  items     ItemTag[]
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model Batch {
  id           String        @id @default(uuid())
  batchCode    String        @unique
  description  String?
  createdAt    DateTime      @default(now())
  customFields CustomField[]
  items        Item[]
}

model Status {
  id             String             @id @default(uuid())
  name           String             @unique
  orderIndex     Int                @default(0)
  items          Item[]
  fromTransition StatusTransition[] @relation("FromStatus")
  toTransition   StatusTransition[] @relation("ToStatus")
}

model StatusTransition {
  id           String @id @default(uuid())
  fromStatusId String
  toStatusId   String
  fromStatus   Status @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus     Status @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([fromStatusId, toStatusId])
}

model CustomField {
  id          String           @id @default(uuid())
  name        String
  fieldType   String
  options     Json?
  required    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  batchId     String?
  orderIndex  Int              @default(0)
  batch       Batch?           @relation(fields: [batchId], references: [id])
  fieldValues ItemFieldValue[]
}

model ItemFieldValue {
  id        String      @id @default(uuid())
  itemId    String
  fieldId   String
  value     Json
  createdAt DateTime    @default(now())
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  item      Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  itemId    String?
  action    String
  changes   Json?
  createdAt DateTime @default(now())
  item      Item?    @relation(fields: [itemId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Location {
  id               String               @id @default(uuid())
  name             String               @unique
  description      String?
  userId           String?              @unique // Link to a staff user for personal inventory
  createdAt        DateTime             @default(now())
  internalRequests InternalRequest[]    @relation("SourceLocation")
  targetRequests   InternalRequest[]    @relation("TargetLocation")
  stocks           ProductStock[]
  transactions     ProductTransaction[]
}

model Product {
  id               String               @id @default(uuid())
  sku              String               @unique
  name             String
  description      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  price            Float                @default(0)
  threshold        Float                @default(0)
  unit             String               @default("PCS")
  imageUrl         String?
  internalRequests InternalRequest[]
  stocks           ProductStock[]
  transactions     ProductTransaction[]
}

model ProductStock {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  quantity   Int      @default(0)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model ProductTransaction {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  type       String
  quantity   Int
  remarks    String?
  createdAt  DateTime @default(now())
  userId     String
  location   Location @relation(fields: [locationId], references: [id])
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
}

model PurchaseRequest {
  id              String   @id @default(uuid())
  prNo            String
  date            DateTime @default(now())
  department      String
  endUser         String
  position        String?
  sourceSupplier  String?
  items           Json
  preparedBy      String?
  checkedBy       String?
  receivedBy      String?
  approvedBy      String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  subTitle        String?
  remarks         String?
  signatoryConfig Json?
  customSubHeader String?
}

model InternalRequest {
  id               String   @id @default(uuid())
  requestNo        String   @unique
  date             DateTime @default(now())
  employeeName     String
  employeeRole     String
  departmentArea   String
  shift            String
  supervisor       String
  locationId       String   // Source Location
  targetLocationId String?  // Optional Target Location (for transfers)
  productId        String
  quantity         Int
  status           String   @default("PENDING")
  remarks          String?
  createdAt        DateTime @default(now())
  location         Location @relation("SourceLocation", fields: [locationId], references: [id])
  targetLocation   Location? @relation("TargetLocation", fields: [targetLocationId], references: [id])
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
