model Fabric {
  id                String              @id @default(uuid())
  name              String              @unique
  type              String
  color             String?
  unit              String              @default("Roll")
  unitPrice         Float               @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  transactions      FabricTransaction[]
  tailoringRequests TailoringRequest[]
  apparels          Apparel[]

  @@schema("public")
}

model Apparel {
  id        String   @id @default(uuid())
  name      String   @unique
  fabricId  String?
  fabric    Fabric?  @relation(fields: [fabricId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model Tailor {
  id                String             @id @default(uuid())
  name              String             @unique
  address           String?
  contactPerson     String?
  contactNumber     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tailoringRequests TailoringRequest[]

  @@schema("public")
}

model FabricTransaction {
  id            String   @id @default(uuid())
  transactionNo String   @unique
  fabricId      String
  type          String // STOCK_IN, WITHDRAWAL, RETURN, INITIAL_BALANCE
  quantity      Float
  unit          String
  remarks       String?
  date          DateTime @default(now())
  location      String?  @default("BODEGA")
  createdAt     DateTime @default(now())
  fabric        Fabric   @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@index([fabricId])
  @@index([date])
  @@schema("public")
}

model StockNotification {
  id                   String              @id @default(uuid())
  productTransactionId String?
  productId            String
  productName          String
  type                 String
  quantity             Int
  message              String
  durationHours        Int                 @default(24)
  createdAt            DateTime            @default(now())
  expiresAt            DateTime
  createdBy            String
  dismissed            Boolean             @default(false)
  product              Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productTransaction   ProductTransaction? @relation(fields: [productTransactionId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
  @@index([dismissed])
  @@schema("public")
}

model TailoringRequest {
  id               String    @id @default(uuid())
  rsqNo            String   @unique
  fabricId         String?
  productId        String? // Finished product link
  tailorId         String
  quantityOrdered  Float
  quantityReceived Float    @default(0)
  unit             String   @default("pcs")
  orderDate        DateTime @default(now())
  targetDate       DateTime?
  status           String   @default("PENDING") // PENDING, IN_PRODUCTION, COMPLETED, CANCELLED
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  fabric           Fabric?  @relation(fields: [fabricId], references: [id])
  product          Product? @relation(fields: [productId], references: [id])
  tailor           Tailor   @relation(fields: [tailorId], references: [id])

  @@index([status])
  @@index([orderDate])
  @@schema("public")
}

model Transmittal {
  id              String   @id @default(uuid())
  transmittalNo   String   @unique
  date            DateTime @default(now())
  subject         String?
  department      String?
  endUser         String?
  position        String?
  sourceSupplier  String?
  subTitle        String?
  customSubHeader String?
  transmittalType String   @default("MATERIAL")
  items           Json
  preparedBy      String?
  checkedBy       String?
  receivedBy      String?
  approvedBy      String?
  signatoryConfig Json?
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("public")
}
