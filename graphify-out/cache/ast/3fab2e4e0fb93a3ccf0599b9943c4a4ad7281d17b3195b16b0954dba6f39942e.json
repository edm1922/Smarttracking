e if (!finalSpecs) {\n                              return toast.error('Specs required');\n                            }\n                            setManualForm({ ...manualForm, rows: [...manualForm.rows, { specs: finalSpecs, qty: currentRow.qty, unit: currentRow.unit || 'pcs' }] });\n                            setCurrentRow({ specs: '', qty: 1, unit: 'pcs' });\n                          }} className=\"w-full py-3 bg-primary text-white rounded-xl text-[10px] font-black uppercase tracking-widest\">+ Add</button>\n                        </div>\n                      </>\n                    );\n                  })", "is_member_call": false, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L551"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "map", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L612"}]}