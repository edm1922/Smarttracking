ation": "L268"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "filter", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L640"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "filter", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L658"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "(() => {\r\n                const pendingFromScans = myRequests.filter(r => r.status === 'PENDING' && !cart.some(c => c.id === r.id));\r\n                if (pendingFromScans.length === 0) return null;\r\n                \r\n                return (\r\n                  <div className=\"bg-orange-50/50 rounded-[2rem] border border-orange-100 p-6 space-y-4 animate-in slide-in-from-top-4 mb-4\">\r\n                    <div className=\"flex items-center justify-between px-2\">\r\n                      <div className=\"flex items-center gap-2\">\r\n                        <div className=\"h-8 w-8 bg-orange-600/10 rounded-xl flex items-center justify-center\">\r\n                          <History className=\"h-4 w-4 text-orange-600\" />\r\n                        </div>\r\n                        <div>\r\n                          <h3 className=\"text-[10px] font-black text-gray-900 uppercase tracking-widest\">Pending from QR Scans</h3>\r\n                          <p className=\"text-[8px] font-bold text-orange-600/60 uppercase tracking-tighter\">Scan QR, review here, then submit</p>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n\r\n                    <div className=\"grid grid-cols-1 gap-2\">\r\n                      {pendingFromScans.map((item) => (\r\n                        <div key={item.id} className=\"bg-white p-4 rounded-2xl border border-orange-100/50 flex items-center justify-between hover:border-orange-500/30 transition-all group shadow-sm\">\r\n                          <div className=\"flex items-center gap-3\">\r\n                            <div className=\"h-10 w-10 bg-gray-50 rounded-xl overflow-hidden flex items-center justify-center border border-gray-100\">\r\n                               {item.imageUrl ? <img src={item.imageUrl} className=\"w-full h-full object-cover\" alt=\"QR\" /> : <QrCode className=\"h-4 w-4 text-gray-300\" />}\r\n                            </div>\r\n                            <div>\r\n                              <p className=\"text-xs font-mono font-bold text-gray-900 leading-none mb-1\">{item.item?.slug || item.itemId}</p>\r\n                              <p className=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest\">\r\n                                {item.qty} {item.unit}\r\n                                {item.item?.fieldValues && (\r\n                                  <span className=\"ml-2 text-primary/60\">\r\n                                    \u2022 {item.item.fieldValues.filter((fv: any) => fv.value).map((fv: any) => typeof fv.value === 'object' ? (fv.value.main || '') : fv.value).filter(Boolean).join(', ')}\r\n                                  </span>\r\n                                )}\r\n                              </p>\r\n                            </div>\r\n                          </div>\r\n                          <div className=\"flex items-center gap-2\">\r\n                            <button \r\n                              onClick={() => handleDeleteRequest(item.id)}\r\n                              className=\"p-2.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all\"\r\n                              title=\"Delete Request\"\r\n                            >\r\n                              <Trash2 className=\"h-4 w-4\" />\r\n                            </button>\r\n                            <button \r\n                              onClick={() => {\r\n                                const cartItem: CartItem = {\r\n                                  id: item.id,\r\n                                  slug: item.item?.slug || item.itemId,\r\n                                  productName: item.item?.name,\r\n                                  manualSlug: item.item?.slug || item.itemId,\r\n                                  qty: item.qty,\r\n                                  unit: item.unit || 'pcs',\r\n                                  specs: item.item?.fieldValues?.filter((fv: any) => fv.value).map((fv: any) => {\r\n                                    const v = fv.value;\r\n                                    const displayVal = typeof v === 'object' ? (v.main || '') : v;\r\n                                    return displayVal ? `${fv.name}: ${displayVal}` : null;\r\n                                  }).filter(Boolean).join(', '),\r\n                                  imagePreview: null,\r\n                                  referencePreview: item.imageUrl,\r\n                                  status: 'success'\r\n                                };\r\n                                setCart(prev => [...prev, cartItem]);\r\n                                if (item.supervisor && !form.supervisorName) {\r\n                                  setForm(prev => ({ ...prev, supervisorName: item.supervisor }));\r\n                                }\r\n                              }}\r\n                              className=\"px-4 py-2 bg-orange-600 text-white rounded-xl text-[9px] font-black uppercase tracking-widest shadow-lg shadow-orange-900/20 active:scale-95 transition-all flex items-center gap-2\"\r\n                            >\r\n                              <Plus className=\"h-3 w-3\" /> Add to Form\r\n                            </button>\r\n                          </div>\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n                );\r\n              })", "is_member_call": false, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L686"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "map", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L818"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "map", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L979"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "map", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L1125"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "filter", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L1125"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "filter", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L1162"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "min", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit-requisition\\page.tsx", "source_location": "L1176"}, {"caller_nid": "unit_requisition_page_unitrequisitioncontent", "callee": "map", "is_member_call": true, "source_file": "D:\\APPS DEVELOPMENT\\Smarttracking\\frontend\\src\\app\\dashboard\\staff\\unit